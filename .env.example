# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Facebook / Instagram app credentials (from the Meta App dashboard).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# OAuth redirect. Must match EXACTLY what is registered in the Meta app:
# http, port 5000, no trailing slash.
REDIRECT_URI=http://localhost:5000/auth/callback

# Instagram Graph API version. v22.0 venció en feb 2026.
GRAPH_API_VERSION=v23.0

# Path to the SQLite database file. If unset, defaults to an absolute path
# under the app's instance/ folder.
DATABASE=instance/reportes.db

# Local debug mode. 0 = off (default). Set to 1 ONLY for local development to
# enable the Werkzeug debugger; never enable it in production.
FLASK_DEBUG=0

# Key to encrypt access tokens at rest (Fernet). Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Secure session cookies require HTTPS. Use False for local http development;
# in production this MUST be True.
SESSION_COOKIE_SECURE=False
