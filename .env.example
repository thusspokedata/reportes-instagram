# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Facebook / Instagram app credentials (from the Meta App dashboard).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# OAuth redirect. Debe coincidir EXACTAMENTE con el registrado en la app de
# Meta: HTTPS, sin barra final. Meta exige HTTPS, así que en desarrollo se usa
# un túnel ngrok con dev domain fijo. Reemplazá TU-SUBDOMINIO por el tuyo.
REDIRECT_URI=https://TU-SUBDOMINIO.ngrok-free.dev/auth/callback

# Instagram Graph API version (v22.0 venció en feb 2026).
GRAPH_API_VERSION=v23.0

# Path to the SQLite database file. If unset, defaults to an absolute path
# under the app's instance/ folder.
DATABASE=instance/reportes.db

# Local debug mode. 0 = off (default). Set to 1 ONLY for local development to
# enable the Werkzeug debugger; never enable it in production.
FLASK_DEBUG=0

# Key to encrypt access tokens at rest (Fernet). Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Secure session cookies require HTTPS. El flujo de desarrollo usa ngrok (HTTPS),
# así que True funciona y es lo recomendado. Poné False SÓLO si servís la app en
# http://localhost plano (sin ngrok); en producción SIEMPRE True.
SESSION_COOKIE_SECURE=True

# --- Reporte de texto con la API de Claude (Messages API) -------------------
# Clave de la API de Anthropic. SECRETO: nunca se versiona ni se loguea. Opcional
# para arrancar; sólo se exige al generar un reporte (si falta, la función
# degrada con un aviso). Obtené una en https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Modelo para el reporte. Por defecto el más económico (Haiku 4.5). Acepta el
# alias (claude-haiku-4-5) o el ID con fecha (claude-haiku-4-5-20251001).
REPORT_MODEL=claude-haiku-4-5
